{
  "version": 2,
  "builds": [
    {
      "src": "api/generate.py",
      "use": "@vercel/python"
    },
    {
      "src": "**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/generate.py"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "images": {
    "sizes": [
      256,
      512,
      1024
    ],
    "domains": [],
    "minimumCacheTTL": 60,
    "formats": [
      "image/avif",
      "image/webp"
    ]
  },
  "cleanUrls": true
}